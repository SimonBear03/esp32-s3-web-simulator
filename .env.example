# Development defaults. Anonymous production must use the dedicated OCI broker.
SIMULATOR_RUNTIME_ROOT=.runtime
SIMULATOR_QEMU_EXECUTABLE=.cache/qemu/source/build/qemu-system-xtensa
SIMULATOR_QEMU_ROM_DIRECTORY=.cache/qemu/source/pc-bios
SIMULATOR_NATIVE_WORKERS_ENABLED=false
SIMULATOR_WORKER_QMP_ENABLED=true
SIMULATOR_WORKER_DEBUG_ENABLED=true
SIMULATOR_WORKER_SANDBOX_MODE=direct
SIMULATOR_WORKER_SANDBOX_EXECUTABLE=/usr/bin/bwrap
SIMULATOR_WORKER_SANDBOX_READONLY_PATHS=/usr:/lib:/lib64
# Core-side OCI settings are required only when mode is oci-broker.
# SIMULATOR_WORKER_BROKER_SOCKET=/run/esp32-simulator/worker-broker.sock
# SIMULATOR_SHARED_GROUP_GID=replace-with-dedicated-shared-gid
# Broker-only settings must be supplied by its protected service environment:
# SIMULATOR_ROOTLESS_DOCKER_HOST=unix:///run/user/replace-with-broker-uid/docker.sock
# SIMULATOR_WORKER_IMAGE=sha256:replace-with-64-hex-image-id
# SIMULATOR_WORKER_SECCOMP_PROFILE=/etc/esp32-simulator/worker-seccomp.json
# SIMULATOR_WORKER_APPARMOR_PROFILE=esp32-s3-simulator-worker
# SIMULATOR_ALLOWED_CORE_UID=replace-with-core-uid
SIMULATOR_MAX_SESSIONS=2
SIMULATOR_SESSION_TTL_SECONDS=120
SIMULATOR_WORKER_MEMORY_LIMIT_MIB=1536
SIMULATOR_WORKER_CPU_LIMIT_SECONDS=90
SIMULATOR_WORKER_STARTUP_TIMEOUT_SECONDS=10
SIMULATOR_FRAMEBUFFER_INTERVAL_MS=100
