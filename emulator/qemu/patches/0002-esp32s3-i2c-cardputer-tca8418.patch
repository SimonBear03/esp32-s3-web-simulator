diff --git a/hw/input/tca8418.c b/hw/input/tca8418.c
new file mode 100644
index 0000000000000000000000000000000000000000..cd011d223a4a65f0b4706bec0a94cf42f75b4727
--- /dev/null
+++ b/hw/input/tca8418.c
@@ -0,0 +1,363 @@
+/*
+ * Texas Instruments TCA8418 keypad scanner
+ *
+ * Copyright (c) 2026 SimonBear03 contributors
+ *
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#include "qemu/osdep.h"
+#include "hw/i2c/i2c.h"
+#include "hw/input/tca8418.h"
+#include "hw/irq.h"
+#include "migration/vmstate.h"
+#include "qemu/module.h"
+#include "ui/console.h"
+
+#define TCA8418_REGISTER_COUNT 0x2f
+#define TCA8418_FIFO_LENGTH 10
+
+#define TCA8418_REG_CFG 0x01
+#define TCA8418_REG_INT_STAT 0x02
+#define TCA8418_REG_KEY_LCK_EC 0x03
+#define TCA8418_REG_KEY_EVENT_A 0x04
+#define TCA8418_REG_KEY_EVENT_J 0x0d
+#define TCA8418_REG_GPIO_DAT_STAT_1 0x14
+#define TCA8418_REG_GPIO_DAT_STAT_2 0x15
+#define TCA8418_REG_GPIO_DAT_STAT_3 0x16
+
+#define TCA8418_CFG_AI 0x80
+#define TCA8418_CFG_OVR_FLOW_M 0x20
+#define TCA8418_CFG_OVR_FLOW_IEN 0x08
+#define TCA8418_CFG_KE_IEN 0x01
+
+#define TCA8418_INT_OVR_FLOW 0x08
+#define TCA8418_INT_KEY_EVENT 0x01
+
+OBJECT_DECLARE_SIMPLE_TYPE(TCA8418State, TCA8418)
+
+struct TCA8418State {
+    I2CSlave parent_obj;
+
+    uint8_t registers[TCA8418_REGISTER_COUNT];
+    uint8_t pointer;
+    bool expect_pointer;
+
+    uint8_t fifo[TCA8418_FIFO_LENGTH];
+    uint8_t fifo_head;
+    uint8_t fifo_count;
+    bool pressed[81];
+
+    qemu_irq irq;
+    QemuInputHandlerState *input_handler;
+};
+
+static void tca8418_update_irq(TCA8418State *s)
+{
+    uint8_t config = s->registers[TCA8418_REG_CFG];
+    uint8_t status = s->registers[TCA8418_REG_INT_STAT];
+    bool asserted = ((status & TCA8418_INT_KEY_EVENT) &&
+                     (config & TCA8418_CFG_KE_IEN)) ||
+                    ((status & TCA8418_INT_OVR_FLOW) &&
+                     (config & TCA8418_CFG_OVR_FLOW_IEN));
+
+    /* The hardware interrupt output is active-low and open-drain. */
+    qemu_set_irq(s->irq, !asserted);
+}
+
+static uint8_t tca8418_key_event_register(TCA8418State *s, unsigned int index)
+{
+    if (index >= s->fifo_count) {
+        return 0;
+    }
+    return s->fifo[(s->fifo_head + index) % TCA8418_FIFO_LENGTH];
+}
+
+static uint8_t tca8418_pop_event(TCA8418State *s)
+{
+    uint8_t event;
+
+    if (s->fifo_count == 0) {
+        return 0;
+    }
+
+    event = s->fifo[s->fifo_head];
+    s->fifo_head = (s->fifo_head + 1) % TCA8418_FIFO_LENGTH;
+    s->fifo_count--;
+    if (s->fifo_count == 0) {
+        s->registers[TCA8418_REG_INT_STAT] &= ~TCA8418_INT_KEY_EVENT;
+    }
+    tca8418_update_irq(s);
+    return event;
+}
+
+static void tca8418_push_event(TCA8418State *s, uint8_t event)
+{
+    unsigned int tail;
+
+    if (s->fifo_count == TCA8418_FIFO_LENGTH) {
+        s->registers[TCA8418_REG_INT_STAT] |= TCA8418_INT_OVR_FLOW;
+        if (!(s->registers[TCA8418_REG_CFG] & TCA8418_CFG_OVR_FLOW_M)) {
+            tca8418_update_irq(s);
+            return;
+        }
+        s->fifo_head = (s->fifo_head + 1) % TCA8418_FIFO_LENGTH;
+        s->fifo_count--;
+    }
+
+    tail = (s->fifo_head + s->fifo_count) % TCA8418_FIFO_LENGTH;
+    s->fifo[tail] = event;
+    s->fifo_count++;
+    s->registers[TCA8418_REG_INT_STAT] |= TCA8418_INT_KEY_EVENT;
+    tca8418_update_irq(s);
+}
+
+static bool tca8418_qcode_to_position(QKeyCode qcode, uint8_t *x, uint8_t *y)
+{
+    static const int8_t positions[Q_KEY_CODE__MAX][2] = {
+        [Q_KEY_CODE_GRAVE_ACCENT] = { 0, 0 },
+        [Q_KEY_CODE_1] = { 1, 0 }, [Q_KEY_CODE_2] = { 2, 0 },
+        [Q_KEY_CODE_3] = { 3, 0 }, [Q_KEY_CODE_4] = { 4, 0 },
+        [Q_KEY_CODE_5] = { 5, 0 }, [Q_KEY_CODE_6] = { 6, 0 },
+        [Q_KEY_CODE_7] = { 7, 0 }, [Q_KEY_CODE_8] = { 8, 0 },
+        [Q_KEY_CODE_9] = { 9, 0 }, [Q_KEY_CODE_0] = { 10, 0 },
+        [Q_KEY_CODE_MINUS] = { 11, 0 }, [Q_KEY_CODE_EQUAL] = { 12, 0 },
+        [Q_KEY_CODE_BACKSPACE] = { 13, 0 },
+
+        [Q_KEY_CODE_TAB] = { 0, 1 }, [Q_KEY_CODE_Q] = { 1, 1 },
+        [Q_KEY_CODE_W] = { 2, 1 }, [Q_KEY_CODE_E] = { 3, 1 },
+        [Q_KEY_CODE_R] = { 4, 1 }, [Q_KEY_CODE_T] = { 5, 1 },
+        [Q_KEY_CODE_Y] = { 6, 1 }, [Q_KEY_CODE_U] = { 7, 1 },
+        [Q_KEY_CODE_I] = { 8, 1 }, [Q_KEY_CODE_O] = { 9, 1 },
+        [Q_KEY_CODE_P] = { 10, 1 }, [Q_KEY_CODE_BRACKET_LEFT] = { 11, 1 },
+        [Q_KEY_CODE_BRACKET_RIGHT] = { 12, 1 },
+        [Q_KEY_CODE_BACKSLASH] = { 13, 1 },
+
+        [Q_KEY_CODE_META_L] = { 0, 2 },
+        [Q_KEY_CODE_SHIFT] = { 1, 2 }, [Q_KEY_CODE_SHIFT_R] = { 1, 2 },
+        [Q_KEY_CODE_A] = { 2, 2 }, [Q_KEY_CODE_S] = { 3, 2 },
+        [Q_KEY_CODE_D] = { 4, 2 }, [Q_KEY_CODE_F] = { 5, 2 },
+        [Q_KEY_CODE_G] = { 6, 2 }, [Q_KEY_CODE_H] = { 7, 2 },
+        [Q_KEY_CODE_J] = { 8, 2 }, [Q_KEY_CODE_K] = { 9, 2 },
+        [Q_KEY_CODE_L] = { 10, 2 }, [Q_KEY_CODE_SEMICOLON] = { 11, 2 },
+        [Q_KEY_CODE_APOSTROPHE] = { 12, 2 }, [Q_KEY_CODE_RET] = { 13, 2 },
+
+        [Q_KEY_CODE_CTRL] = { 0, 3 }, [Q_KEY_CODE_CTRL_R] = { 0, 3 },
+        [Q_KEY_CODE_META_R] = { 1, 3 }, [Q_KEY_CODE_MENU] = { 1, 3 },
+        [Q_KEY_CODE_ALT] = { 2, 3 }, [Q_KEY_CODE_ALT_R] = { 2, 3 },
+        [Q_KEY_CODE_Z] = { 3, 3 }, [Q_KEY_CODE_X] = { 4, 3 },
+        [Q_KEY_CODE_C] = { 5, 3 }, [Q_KEY_CODE_V] = { 6, 3 },
+        [Q_KEY_CODE_B] = { 7, 3 }, [Q_KEY_CODE_N] = { 8, 3 },
+        [Q_KEY_CODE_M] = { 9, 3 }, [Q_KEY_CODE_COMMA] = { 10, 3 },
+        [Q_KEY_CODE_DOT] = { 11, 3 }, [Q_KEY_CODE_SLASH] = { 12, 3 },
+        [Q_KEY_CODE_SPC] = { 13, 3 },
+    };
+
+    if (qcode < 0 || qcode >= Q_KEY_CODE__MAX ||
+        (positions[qcode][0] == 0 && positions[qcode][1] == 0 &&
+         qcode != Q_KEY_CODE_GRAVE_ACCENT)) {
+        return false;
+    }
+
+    *x = positions[qcode][0];
+    *y = positions[qcode][1];
+    return true;
+}
+
+static uint8_t tca8418_position_to_event(uint8_t x, uint8_t y)
+{
+    uint8_t raw_row = x / 2;
+    uint8_t raw_column = y + ((x & 1) ? 4 : 0);
+
+    return raw_row * 10 + raw_column + 1;
+}
+
+static void tca8418_input_event(DeviceState *dev, QemuConsole *src,
+                                InputEvent *evt)
+{
+    TCA8418State *s = TCA8418(dev);
+    InputKeyEvent *key = evt->u.key.data;
+    QKeyCode qcode = qemu_input_key_value_to_qcode(key->key);
+    uint8_t x, y, code;
+
+    if (!tca8418_qcode_to_position(qcode, &x, &y)) {
+        return;
+    }
+
+    code = tca8418_position_to_event(x, y);
+    if (s->pressed[code] == key->down) {
+        return;
+    }
+
+    s->pressed[code] = key->down;
+    tca8418_push_event(s, code | (key->down ? 0x80 : 0));
+}
+
+static const QemuInputHandler tca8418_input_handler = {
+    .name = "TCA8418 keypad",
+    .mask = INPUT_EVENT_MASK_KEY,
+    .event = tca8418_input_event,
+};
+
+static uint8_t tca8418_read_register(TCA8418State *s, uint8_t reg)
+{
+    if (reg == TCA8418_REG_KEY_LCK_EC) {
+        return (s->registers[reg] & 0xf0) | s->fifo_count;
+    }
+    if (reg == TCA8418_REG_KEY_EVENT_A) {
+        return tca8418_pop_event(s);
+    }
+    if (reg > TCA8418_REG_KEY_EVENT_A && reg <= TCA8418_REG_KEY_EVENT_J) {
+        return tca8418_key_event_register(s, reg - TCA8418_REG_KEY_EVENT_A);
+    }
+    if (reg >= TCA8418_REGISTER_COUNT) {
+        return 0;
+    }
+    return s->registers[reg];
+}
+
+static void tca8418_write_register(TCA8418State *s, uint8_t reg, uint8_t value)
+{
+    if (reg >= TCA8418_REGISTER_COUNT) {
+        return;
+    }
+
+    switch (reg) {
+    case TCA8418_REG_CFG:
+        s->registers[reg] = value;
+        tca8418_update_irq(s);
+        break;
+    case TCA8418_REG_INT_STAT:
+        s->registers[reg] &= ~value;
+        if (s->fifo_count) {
+            s->registers[reg] |= TCA8418_INT_KEY_EVENT;
+        }
+        tca8418_update_irq(s);
+        break;
+    case TCA8418_REG_KEY_LCK_EC:
+        s->registers[reg] = value & 0xf0;
+        break;
+    case TCA8418_REG_KEY_EVENT_A ... TCA8418_REG_KEY_EVENT_J:
+        break;
+    default:
+        s->registers[reg] = value;
+        break;
+    }
+}
+
+static int tca8418_event(I2CSlave *i2c, enum i2c_event event)
+{
+    TCA8418State *s = TCA8418(i2c);
+
+    if (event == I2C_START_SEND) {
+        s->expect_pointer = true;
+    }
+    return 0;
+}
+
+static int tca8418_send(I2CSlave *i2c, uint8_t data)
+{
+    TCA8418State *s = TCA8418(i2c);
+
+    if (s->expect_pointer) {
+        s->pointer = data;
+        s->expect_pointer = false;
+    } else {
+        tca8418_write_register(s, s->pointer, data);
+        if (s->registers[TCA8418_REG_CFG] & TCA8418_CFG_AI) {
+            s->pointer++;
+        }
+    }
+    return 0;
+}
+
+static uint8_t tca8418_recv(I2CSlave *i2c)
+{
+    TCA8418State *s = TCA8418(i2c);
+    uint8_t value = tca8418_read_register(s, s->pointer);
+
+    if (s->registers[TCA8418_REG_CFG] & TCA8418_CFG_AI) {
+        s->pointer++;
+    }
+    return value;
+}
+
+static void tca8418_reset(DeviceState *dev)
+{
+    TCA8418State *s = TCA8418(dev);
+
+    memset(s->registers, 0, sizeof(s->registers));
+    s->registers[TCA8418_REG_GPIO_DAT_STAT_1] = 0xff;
+    s->registers[TCA8418_REG_GPIO_DAT_STAT_2] = 0xff;
+    s->registers[TCA8418_REG_GPIO_DAT_STAT_3] = 0x03;
+    s->pointer = 0;
+    s->expect_pointer = false;
+    s->fifo_head = 0;
+    s->fifo_count = 0;
+    memset(s->fifo, 0, sizeof(s->fifo));
+    memset(s->pressed, 0, sizeof(s->pressed));
+    tca8418_update_irq(s);
+}
+
+static void tca8418_realize(DeviceState *dev, Error **errp)
+{
+    TCA8418State *s = TCA8418(dev);
+
+    qdev_init_gpio_out_named(dev, &s->irq, "nINT", 1);
+    s->input_handler = qemu_input_handler_register(dev, &tca8418_input_handler);
+}
+
+static void tca8418_unrealize(DeviceState *dev)
+{
+    TCA8418State *s = TCA8418(dev);
+
+    if (s->input_handler) {
+        qemu_input_handler_unregister(s->input_handler);
+        s->input_handler = NULL;
+    }
+}
+
+static const VMStateDescription vmstate_tca8418 = {
+    .name = TYPE_TCA8418,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (VMStateField[]) {
+        VMSTATE_I2C_SLAVE(parent_obj, TCA8418State),
+        VMSTATE_UINT8_ARRAY(registers, TCA8418State, TCA8418_REGISTER_COUNT),
+        VMSTATE_UINT8(pointer, TCA8418State),
+        VMSTATE_BOOL(expect_pointer, TCA8418State),
+        VMSTATE_UINT8_ARRAY(fifo, TCA8418State, TCA8418_FIFO_LENGTH),
+        VMSTATE_UINT8(fifo_head, TCA8418State),
+        VMSTATE_UINT8(fifo_count, TCA8418State),
+        VMSTATE_BOOL_ARRAY(pressed, TCA8418State, 81),
+        VMSTATE_END_OF_LIST()
+    },
+};
+
+static void tca8418_class_init(ObjectClass *klass, void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+    I2CSlaveClass *sc = I2C_SLAVE_CLASS(klass);
+
+    dc->realize = tca8418_realize;
+    dc->unrealize = tca8418_unrealize;
+    device_class_set_legacy_reset(dc, tca8418_reset);
+    dc->vmsd = &vmstate_tca8418;
+    sc->event = tca8418_event;
+    sc->recv = tca8418_recv;
+    sc->send = tca8418_send;
+}
+
+static const TypeInfo tca8418_info = {
+    .name = TYPE_TCA8418,
+    .parent = TYPE_I2C_SLAVE,
+    .instance_size = sizeof(TCA8418State),
+    .class_init = tca8418_class_init,
+};
+
+static void tca8418_register_types(void)
+{
+    type_register_static(&tca8418_info);
+}
+
+type_init(tca8418_register_types)
