@@ -39,9 +215,106 @@ static uint64_t esp32_gpio_read(void *opaque, hwaddr addr, unsigned int size)
 static void esp32_gpio_write(void *opaque, hwaddr addr,
                        uint64_t value, unsigned int size)
 {
+    Esp32GpioState *s = ESP32_GPIO(opaque);
+    uint64_t mask = value;
+    uint64_t changed = 0;
+
+    if (!s->s3_mode) {
+        return;
+    }
+
+    switch (addr) {
+    case S3_GPIO_OUT:
+        changed = s->output_level ^ (uint32_t)value;
+        s->output_level = (s->output_level & ~UINT32_MAX) | (uint32_t)value;
+        break;
+    case S3_GPIO_OUT_W1TS:
+        changed = ~s->output_level & (uint32_t)value;
+        s->output_level |= (uint32_t)value;
+        break;
+    case S3_GPIO_OUT_W1TC:
+        changed = s->output_level & (uint32_t)value;
+        s->output_level &= ~(uint64_t)(uint32_t)value;
+        break;
+    case S3_GPIO_OUT1:
+        mask <<= 32;
+        changed = (s->output_level ^ mask) & (UINT64_MAX << 32);
+        s->output_level = (s->output_level & UINT32_MAX) | mask;
+        break;
+    case S3_GPIO_OUT1_W1TS:
+        mask <<= 32;
+        changed = ~s->output_level & mask;
+        s->output_level |= mask;
+        break;
+    case S3_GPIO_OUT1_W1TC:
+        mask <<= 32;
+        changed = s->output_level & mask;
+        s->output_level &= ~mask;
+        break;
+    case S3_GPIO_ENABLE:
+        changed = s->output_enable ^ (uint32_t)value;
+        s->output_enable = (s->output_enable & ~UINT32_MAX) | (uint32_t)value;
+        break;
+    case S3_GPIO_ENABLE_W1TS:
+        changed = ~s->output_enable & (uint32_t)value;
+        s->output_enable |= (uint32_t)value;
+        break;
+    case S3_GPIO_ENABLE_W1TC:
+        changed = s->output_enable & (uint32_t)value;
+        s->output_enable &= ~(uint64_t)(uint32_t)value;
+        break;
+    case S3_GPIO_ENABLE1:
+        mask <<= 32;
+        changed = (s->output_enable ^ mask) & (UINT64_MAX << 32);
+        s->output_enable = (s->output_enable & UINT32_MAX) | mask;
+        break;
+    case S3_GPIO_ENABLE1_W1TS:
+        mask <<= 32;
+        changed = ~s->output_enable & mask;
+        s->output_enable |= mask;
+        break;
+    case S3_GPIO_ENABLE1_W1TC:
+        mask <<= 32;
+        changed = s->output_enable & mask;
+        s->output_enable &= ~mask;
+        break;
+    case S3_GPIO_STATUS_W1TS:
+        s->interrupt_status |= (uint32_t)value;
+        esp32_gpio_update_irq(s);
+        return;
+    case S3_GPIO_STATUS_W1TC:
+        mask = (uint32_t)value;
+        s->interrupt_status &= ~mask;
+        esp32_gpio_reassert_levels(s, mask);
+        esp32_gpio_update_irq(s);
+        return;
+    case S3_GPIO_STATUS1_W1TS:
+        s->interrupt_status |= mask << 32;
+        esp32_gpio_update_irq(s);
+        return;
+    case S3_GPIO_STATUS1_W1TC:
+        mask <<= 32;
+        s->interrupt_status &= ~mask;
+        esp32_gpio_reassert_levels(s, mask);
+        esp32_gpio_update_irq(s);
+        return;
+    default:
+        if (addr >= S3_GPIO_PIN_BASE &&
+            addr < S3_GPIO_PIN_BASE + s->pin_count * sizeof(uint32_t) &&
+            !(addr & 3)) {
+            unsigned int pin = (addr - S3_GPIO_PIN_BASE) / sizeof(uint32_t);
+
+            s->pin_config[pin] = value;
+            esp32_gpio_reassert_levels(s, BIT_ULL(pin));
+            esp32_gpio_update_irq(s);
+        }
+        return;
+    }
+
+    esp32_gpio_update_outputs(s, changed);
 }

