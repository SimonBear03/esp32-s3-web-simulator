+#define S3_GPIO_OUT 0x04
+#define S3_GPIO_OUT_W1TS 0x08
+#define S3_GPIO_OUT_W1TC 0x0c
+#define S3_GPIO_OUT1 0x10
+#define S3_GPIO_OUT1_W1TS 0x14
+#define S3_GPIO_OUT1_W1TC 0x18
+#define S3_GPIO_ENABLE 0x20
+#define S3_GPIO_ENABLE_W1TS 0x24
+#define S3_GPIO_ENABLE_W1TC 0x28
+#define S3_GPIO_ENABLE1 0x2c
+#define S3_GPIO_ENABLE1_W1TS 0x30
+#define S3_GPIO_ENABLE1_W1TC 0x34
+#define S3_GPIO_IN 0x3c
+#define S3_GPIO_IN1 0x40
+#define S3_GPIO_STATUS 0x44
+#define S3_GPIO_STATUS_W1TS 0x48
+#define S3_GPIO_STATUS_W1TC 0x4c
+#define S3_GPIO_STATUS1 0x50
+#define S3_GPIO_STATUS1_W1TS 0x54
+#define S3_GPIO_STATUS1_W1TC 0x58
+#define S3_GPIO_PCPU_INT 0x5c
+#define S3_GPIO_PCPU_INT1 0x68
+#define S3_GPIO_PIN_BASE 0x74
+
+#define S3_GPIO_PIN_INT_TYPE_SHIFT 7
+#define S3_GPIO_PIN_INT_TYPE_MASK 0x7
+#define S3_GPIO_PIN_INT_ENA_SHIFT 13
+#define S3_GPIO_PIN_INT_ENA_MASK 0x1f
+
+enum {
+    S3_GPIO_INTR_DISABLE = 0,
+    S3_GPIO_INTR_POSEDGE = 1,
+    S3_GPIO_INTR_NEGEDGE = 2,
+    S3_GPIO_INTR_ANYEDGE = 3,
+    S3_GPIO_INTR_LOW_LEVEL = 4,
+    S3_GPIO_INTR_HIGH_LEVEL = 5,
+};
+
+static uint64_t esp32_gpio_enabled_interrupts(Esp32GpioState *s)
+{
+    uint64_t enabled = 0;
+
+    for (unsigned int pin = 0; pin < s->pin_count; pin++) {
+        if ((s->pin_config[pin] >> S3_GPIO_PIN_INT_ENA_SHIFT) &
+            S3_GPIO_PIN_INT_ENA_MASK) {
+            enabled |= BIT_ULL(pin);
+        }
+    }
+    return enabled;
+}
+
+static void esp32_gpio_update_irq(Esp32GpioState *s)
+{
+    qemu_set_irq(s->irq,
+                 !!(s->interrupt_status & esp32_gpio_enabled_interrupts(s)));
+}
+
+static void esp32_gpio_update_outputs(Esp32GpioState *s, uint64_t changed)
+{
+    changed &= MAKE_64BIT_MASK(0, s->pin_count);
+    while (changed) {
+        unsigned int pin = ctz64(changed);
+        bool level = (s->output_enable & s->output_level) & BIT_ULL(pin);
+
+        qemu_set_irq(s->pin_out[pin], level);
+        changed &= ~BIT_ULL(pin);
+    }
+}
+
+static bool esp32_gpio_level_triggered(Esp32GpioState *s, unsigned int pin)
+{
+    unsigned int type = (s->pin_config[pin] >> S3_GPIO_PIN_INT_TYPE_SHIFT) &
+                        S3_GPIO_PIN_INT_TYPE_MASK;
+    bool level = s->input_level & BIT_ULL(pin);
+
+    return (type == S3_GPIO_INTR_LOW_LEVEL && !level) ||
+           (type == S3_GPIO_INTR_HIGH_LEVEL && level);
+}
+
+static void esp32_gpio_reassert_levels(Esp32GpioState *s, uint64_t pins)
+{
+    for (unsigned int pin = 0; pin < s->pin_count; pin++) {
+        if ((pins & BIT_ULL(pin)) && esp32_gpio_level_triggered(s, pin)) {
+            s->interrupt_status |= BIT_ULL(pin);
+        }
+    }
+}
+
+static void esp32_gpio_set_input(void *opaque, int pin, int level)
+{
+    Esp32GpioState *s = ESP32_GPIO(opaque);
+    uint64_t mask;
+    bool previous;
+    unsigned int type;
+    bool triggered = false;
+
+    if (pin < 0 || pin >= s->pin_count) {
+        return;
+    }
+
+    mask = BIT_ULL(pin);
+    previous = s->input_level & mask;
+    if (level) {
+        s->input_level |= mask;
+    } else {
+        s->input_level &= ~mask;
+    }
+
+    type = (s->pin_config[pin] >> S3_GPIO_PIN_INT_TYPE_SHIFT) &
+           S3_GPIO_PIN_INT_TYPE_MASK;
+    switch (type) {
+    case S3_GPIO_INTR_POSEDGE:
+        triggered = !previous && level;
+        break;
+    case S3_GPIO_INTR_NEGEDGE:
+        triggered = previous && !level;
+        break;
+    case S3_GPIO_INTR_ANYEDGE:
+        triggered = previous != level;
+        break;
+    case S3_GPIO_INTR_LOW_LEVEL:
+        triggered = !level;
+        break;
+    case S3_GPIO_INTR_HIGH_LEVEL:
+        triggered = level;
+        break;
+    default:
+        break;
+    }
+
+    if (triggered) {
+        s->interrupt_status |= mask;
+    }
+    esp32_gpio_update_irq(s);
+}


