+/* SPDX-License-Identifier: GPL-2.0-only */
+
+#ifndef HW_SSI_ESP32S3_GPSPI_H
+#define HW_SSI_ESP32S3_GPSPI_H
+
+#include "hw/ssi/ssi.h"
+#include "hw/sysbus.h"
+
+#define TYPE_ESP32S3_GPSPI "ssi.esp32s3.gpspi"
+OBJECT_DECLARE_SIMPLE_TYPE(ESP32S3GpspiState, ESP32S3_GPSPI)
+
+#define ESP32S3_GPSPI_CS_COUNT 6
+#define ESP32S3_GPSPI_BUFFER_WORDS 16
+#define ESP32S3_GPSPI_IO_SIZE 0x400
+
+struct ESP32S3GpspiState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion iomem;
+    SSIBus *spi;
+    qemu_irq irq;
+    qemu_irq cs[ESP32S3_GPSPI_CS_COUNT];
+
+    uint32_t addr;
+    uint32_t ctrl;
+    uint32_t clock;
+    uint32_t user;
+    uint32_t user1;
+    uint32_t user2;
+    uint32_t ms_dlen;
+    uint32_t misc;
+    uint32_t dma_conf;
+    uint32_t dma_int_ena;
+    uint32_t dma_int_raw;
+    uint32_t data[ESP32S3_GPSPI_BUFFER_WORDS];
+    uint32_t slave;
+    uint32_t clk_gate;
+};
+
+#endif
