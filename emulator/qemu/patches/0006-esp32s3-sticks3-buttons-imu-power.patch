diff --git a/hw/misc/m5pm1.c b/hw/misc/m5pm1.c
new file mode 100644
index 0000000000000000000000000000000000000000..2ce1dadac8a857410e7c3cbb8b0506481e46e049
--- /dev/null
+++ b/hw/misc/m5pm1.c
@@ -0,0 +1,210 @@
+/*
+ * M5Stack M5PM1 power management controller
+ *
+ * Copyright (c) 2026 SimonBear03 contributors
+ *
+ * SPDX-License-Identifier: GPL-2.0-only
+ *
+ * This behavioral model provides firmware-visible configuration and the
+ * battery, input-voltage, source, and charging signals used by StickS3 apps.
+ */
+
+#include "qemu/osdep.h"
+#include "hw/i2c/i2c.h"
+#include "hw/misc/m5pm1.h"
+#include "migration/vmstate.h"
+#include "qapi/error.h"
+#include "qemu/module.h"
+
+#define M5PM1_REGISTER_COUNT 0x80
+
+#define M5PM1_REG_DEVICE_ID 0x00
+#define M5PM1_REG_DEVICE_MODEL 0x01
+#define M5PM1_REG_HW_REV 0x02
+#define M5PM1_REG_SW_REV 0x03
+#define M5PM1_REG_PWR_SRC 0x04
+#define M5PM1_REG_PWR_CFG 0x06
+#define M5PM1_REG_GPIO_IN 0x12
+#define M5PM1_REG_VREF_L 0x20
+#define M5PM1_REG_VBAT_L 0x22
+#define M5PM1_REG_VIN_L 0x24
+#define M5PM1_REG_5VINOUT_L 0x26
+
+OBJECT_DECLARE_SIMPLE_TYPE(M5PM1State, M5PM1)
+
+struct M5PM1State {
+    I2CSlave parent_obj;
+
+    uint8_t registers[M5PM1_REGISTER_COUNT];
+    uint8_t pointer;
+    bool expect_pointer;
+
+    uint16_t battery_mv;
+    uint16_t vin_mv;
+    bool charging;
+};
+
+static void m5pm1_set_voltage(M5PM1State *s, uint8_t reg, uint16_t value)
+{
+    s->registers[reg] = value;
+    s->registers[reg + 1] = value >> 8;
+}
+
+static void m5pm1_update_state_registers(M5PM1State *s)
+{
+    s->registers[M5PM1_REG_PWR_SRC] = s->vin_mv ? 0 : 2;
+    s->registers[M5PM1_REG_GPIO_IN] = s->charging ? 0x00 : 0x01;
+    m5pm1_set_voltage(s, M5PM1_REG_VREF_L, 3300);
+    m5pm1_set_voltage(s, M5PM1_REG_VBAT_L, s->battery_mv);
+    m5pm1_set_voltage(s, M5PM1_REG_VIN_L, s->vin_mv);
+    m5pm1_set_voltage(s, M5PM1_REG_5VINOUT_L, 0);
+}
+
+static char *m5pm1_get_power_state(Object *obj, Error **errp)
+{
+    M5PM1State *s = M5PM1(obj);
+
+    return g_strdup_printf("%u,%u,%u", s->battery_mv, s->vin_mv,
+                           s->charging);
+}
+
+static void m5pm1_set_power_state(Object *obj, const char *value, Error **errp)
+{
+    M5PM1State *s = M5PM1(obj);
+    unsigned int battery_mv;
+    unsigned int vin_mv;
+    unsigned int charging;
+    char trailing;
+
+    if (sscanf(value, "%u,%u,%u%c", &battery_mv, &vin_mv, &charging,
+               &trailing) != 3) {
+        error_setg(errp, "M5PM1 power-state must be battery_mv,vin_mv,charging");
+        return;
+    }
+    if (battery_mv > 6000 || vin_mv > 6000 || charging > 1) {
+        error_setg(errp, "M5PM1 power-state is outside the behavioral model range");
+        return;
+    }
+    s->battery_mv = battery_mv;
+    s->vin_mv = vin_mv;
+    s->charging = charging;
+    m5pm1_update_state_registers(s);
+}
+
+static bool m5pm1_read_only_register(uint8_t reg)
+{
+    return reg <= M5PM1_REG_PWR_SRC || reg == M5PM1_REG_GPIO_IN ||
+           (reg >= M5PM1_REG_VREF_L && reg <= M5PM1_REG_5VINOUT_L + 1);
+}
+
+static uint8_t m5pm1_read_register(M5PM1State *s, uint8_t reg)
+{
+    m5pm1_update_state_registers(s);
+    return reg < M5PM1_REGISTER_COUNT ? s->registers[reg] : 0;
+}
+
+static void m5pm1_write_register(M5PM1State *s, uint8_t reg, uint8_t value)
+{
+    if (reg < M5PM1_REGISTER_COUNT && !m5pm1_read_only_register(reg)) {
+        s->registers[reg] = value;
+    }
+}
+
+static int m5pm1_event(I2CSlave *i2c, enum i2c_event event)
+{
+    M5PM1State *s = M5PM1(i2c);
+
+    if (event == I2C_START_SEND) {
+        s->expect_pointer = true;
+    }
+    return 0;
+}
+
+static int m5pm1_send(I2CSlave *i2c, uint8_t data)
+{
+    M5PM1State *s = M5PM1(i2c);
+
+    if (s->expect_pointer) {
+        s->pointer = data;
+        s->expect_pointer = false;
+    } else {
+        m5pm1_write_register(s, s->pointer++, data);
+    }
+    return 0;
+}
+
+static uint8_t m5pm1_recv(I2CSlave *i2c)
+{
+    M5PM1State *s = M5PM1(i2c);
+
+    return m5pm1_read_register(s, s->pointer++);
+}
+
+static void m5pm1_reset(DeviceState *dev)
+{
+    M5PM1State *s = M5PM1(dev);
+
+    memset(s->registers, 0, sizeof(s->registers));
+    s->registers[M5PM1_REG_DEVICE_ID] = 0x51;
+    s->registers[M5PM1_REG_DEVICE_MODEL] = 0x01;
+    s->registers[M5PM1_REG_HW_REV] = 0x01;
+    s->registers[M5PM1_REG_SW_REV] = 0x01;
+    s->registers[M5PM1_REG_PWR_CFG] = 0x07;
+    s->pointer = 0;
+    s->expect_pointer = false;
+    m5pm1_update_state_registers(s);
+}
+
+static void m5pm1_init(Object *obj)
+{
+    M5PM1State *s = M5PM1(obj);
+
+    s->battery_mv = 3900;
+    s->vin_mv = 5000;
+    s->charging = true;
+    object_property_add_str(obj, "power-state", m5pm1_get_power_state,
+                            m5pm1_set_power_state);
+}
+
+static const VMStateDescription vmstate_m5pm1 = {
+    .name = TYPE_M5PM1,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (VMStateField[]) {
+        VMSTATE_I2C_SLAVE(parent_obj, M5PM1State),
+        VMSTATE_UINT8_ARRAY(registers, M5PM1State, M5PM1_REGISTER_COUNT),
+        VMSTATE_UINT8(pointer, M5PM1State),
+        VMSTATE_BOOL(expect_pointer, M5PM1State),
+        VMSTATE_UINT16(battery_mv, M5PM1State),
+        VMSTATE_UINT16(vin_mv, M5PM1State),
+        VMSTATE_BOOL(charging, M5PM1State),
+        VMSTATE_END_OF_LIST()
+    },
+};
+
+static void m5pm1_class_init(ObjectClass *klass, void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+    I2CSlaveClass *sc = I2C_SLAVE_CLASS(klass);
+
+    device_class_set_legacy_reset(dc, m5pm1_reset);
+    dc->vmsd = &vmstate_m5pm1;
+    sc->event = m5pm1_event;
+    sc->recv = m5pm1_recv;
+    sc->send = m5pm1_send;
+}
+
+static const TypeInfo m5pm1_info = {
+    .name = TYPE_M5PM1,
+    .parent = TYPE_I2C_SLAVE,
+    .instance_size = sizeof(M5PM1State),
+    .instance_init = m5pm1_init,
+    .class_init = m5pm1_class_init,
+};
+
+static void m5pm1_register_types(void)
+{
+    type_register_static(&m5pm1_info);
+}
+
+type_init(m5pm1_register_types)
