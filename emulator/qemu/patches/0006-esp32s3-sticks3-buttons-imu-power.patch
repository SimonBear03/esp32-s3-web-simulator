diff --git a/hw/sensor/bmi270.c b/hw/sensor/bmi270.c
new file mode 100644
index 0000000000000000000000000000000000000000..917aa4d8e78f3e998b6e86b3effb2f249713c9a5
--- /dev/null
+++ b/hw/sensor/bmi270.c
@@ -0,0 +1,260 @@
+/*
+ * Bosch BMI270 inertial measurement unit
+ *
+ * Copyright (c) 2026 SimonBear03 contributors
+ *
+ * SPDX-License-Identifier: GPL-2.0-only
+ *
+ * This behavioral model implements the identification, initialization,
+ * configuration, and polled sample registers used by common StickS3 firmware.
+ */
+
+#include "qemu/osdep.h"
+#include "hw/i2c/i2c.h"
+#include "hw/sensor/bmi270.h"
+#include "migration/vmstate.h"
+#include "qapi/error.h"
+#include "qemu/module.h"
+
+#define BMI270_REGISTER_COUNT 0x80
+
+#define BMI270_REG_CHIP_ID 0x00
+#define BMI270_REG_STATUS 0x03
+#define BMI270_REG_ACC_X_LSB 0x0c
+#define BMI270_REG_GYR_X_LSB 0x12
+#define BMI270_REG_INT_STATUS_1 0x1d
+#define BMI270_REG_INTERNAL_STATUS 0x21
+#define BMI270_REG_ACC_RANGE 0x41
+#define BMI270_REG_GYR_RANGE 0x43
+#define BMI270_REG_INIT_CTRL 0x59
+#define BMI270_REG_INIT_DATA 0x5e
+#define BMI270_REG_PWR_CONF 0x7c
+#define BMI270_REG_CMD 0x7e
+
+#define BMI270_CHIP_ID 0x24
+#define BMI270_CMD_SOFT_RESET 0xb6
+
+OBJECT_DECLARE_SIMPLE_TYPE(BMI270State, BMI270)
+
+struct BMI270State {
+    I2CSlave parent_obj;
+
+    uint8_t registers[BMI270_REGISTER_COUNT];
+    uint8_t pointer;
+    bool expect_pointer;
+    bool init_data_stream;
+
+    int32_t accel_mg[3];
+    int32_t gyro_mdps[3];
+};
+
+static int16_t bmi270_scale(int32_t value, int32_t full_scale)
+{
+    int64_t raw = (int64_t)value * 32768 / full_scale;
+
+    raw = MAX(raw, INT16_MIN);
+    raw = MIN(raw, INT16_MAX);
+    return raw;
+}
+
+static int32_t bmi270_accel_full_scale(const BMI270State *s)
+{
+    static const int32_t ranges_mg[] = { 2000, 4000, 8000, 16000 };
+
+    return ranges_mg[s->registers[BMI270_REG_ACC_RANGE] & 0x03];
+}
+
+static int32_t bmi270_gyro_full_scale(const BMI270State *s)
+{
+    static const int32_t ranges_mdps[] = {
+        2000000, 1000000, 500000, 250000, 125000,
+    };
+    uint8_t range = s->registers[BMI270_REG_GYR_RANGE] & 0x07;
+
+    return range < ARRAY_SIZE(ranges_mdps) ? ranges_mdps[range] : 2000000;
+}
+
+static void bmi270_set_word(BMI270State *s, uint8_t reg, int16_t value)
+{
+    s->registers[reg] = value;
+    s->registers[reg + 1] = value >> 8;
+}
+
+static void bmi270_update_sample_registers(BMI270State *s)
+{
+    unsigned int axis;
+
+    for (axis = 0; axis < 3; axis++) {
+        bmi270_set_word(s, BMI270_REG_ACC_X_LSB + axis * 2,
+                        bmi270_scale(s->accel_mg[axis],
+                                     bmi270_accel_full_scale(s)));
+        bmi270_set_word(s, BMI270_REG_GYR_X_LSB + axis * 2,
+                        bmi270_scale(s->gyro_mdps[axis],
+                                     bmi270_gyro_full_scale(s)));
+    }
+}
+
+static char *bmi270_get_sample(Object *obj, Error **errp)
+{
+    BMI270State *s = BMI270(obj);
+
+    return g_strdup_printf("%d,%d,%d,%d,%d,%d",
+                           s->accel_mg[0], s->accel_mg[1], s->accel_mg[2],
+                           s->gyro_mdps[0], s->gyro_mdps[1], s->gyro_mdps[2]);
+}
+
+static void bmi270_set_sample(Object *obj, const char *value, Error **errp)
+{
+    BMI270State *s = BMI270(obj);
+    int accel[3];
+    int gyro[3];
+    char trailing;
+    unsigned int axis;
+
+    if (sscanf(value, "%d,%d,%d,%d,%d,%d%c",
+               &accel[0], &accel[1], &accel[2],
+               &gyro[0], &gyro[1], &gyro[2], &trailing) != 6) {
+        error_setg(errp, "BMI270 sample must be ax,ay,az,gx,gy,gz in mg/mdps");
+        return;
+    }
+    for (axis = 0; axis < 3; axis++) {
+        if (accel[axis] < -16000 || accel[axis] > 16000 ||
+            gyro[axis] < -2000000 || gyro[axis] > 2000000) {
+            error_setg(errp, "BMI270 sample exceeds physical model range");
+            return;
+        }
+        s->accel_mg[axis] = accel[axis];
+        s->gyro_mdps[axis] = gyro[axis];
+    }
+    bmi270_update_sample_registers(s);
+}
+
+static void bmi270_reset_registers(BMI270State *s)
+{
+    memset(s->registers, 0, sizeof(s->registers));
+    s->registers[BMI270_REG_CHIP_ID] = BMI270_CHIP_ID;
+    s->registers[BMI270_REG_STATUS] = 0xc0;
+    s->registers[BMI270_REG_INT_STATUS_1] = 0xc0;
+    s->registers[BMI270_REG_INTERNAL_STATUS] = 0x01;
+    s->registers[BMI270_REG_ACC_RANGE] = 0x02;
+    s->registers[BMI270_REG_GYR_RANGE] = 0x00;
+    s->registers[BMI270_REG_PWR_CONF] = 0x03;
+    s->pointer = 0;
+    s->expect_pointer = false;
+    s->init_data_stream = false;
+    bmi270_update_sample_registers(s);
+}
+
+static uint8_t bmi270_read_register(BMI270State *s, uint8_t reg)
+{
+    if (reg >= BMI270_REG_ACC_X_LSB && reg < BMI270_REG_GYR_X_LSB + 6) {
+        bmi270_update_sample_registers(s);
+    }
+    return reg < BMI270_REGISTER_COUNT ? s->registers[reg] : 0;
+}
+
+static void bmi270_write_register(BMI270State *s, uint8_t reg, uint8_t value)
+{
+    if (reg >= BMI270_REGISTER_COUNT || reg == BMI270_REG_CHIP_ID) {
+        return;
+    }
+    if (reg == BMI270_REG_CMD && value == BMI270_CMD_SOFT_RESET) {
+        bmi270_reset_registers(s);
+        return;
+    }
+
+    s->registers[reg] = value;
+    if (reg == BMI270_REG_INIT_CTRL && value == 0x01) {
+        s->registers[BMI270_REG_INTERNAL_STATUS] = 0x01;
+    }
+}
+
+static int bmi270_event(I2CSlave *i2c, enum i2c_event event)
+{
+    BMI270State *s = BMI270(i2c);
+
+    if (event == I2C_START_SEND) {
+        s->expect_pointer = true;
+    }
+    return 0;
+}
+
+static int bmi270_send(I2CSlave *i2c, uint8_t data)
+{
+    BMI270State *s = BMI270(i2c);
+
+    if (s->expect_pointer) {
+        s->pointer = data;
+        s->expect_pointer = false;
+        s->init_data_stream = data == BMI270_REG_INIT_DATA;
+    } else if (s->init_data_stream) {
+        /* Configuration bytes use INIT_DATA as a streaming data port. */
+    } else {
+        bmi270_write_register(s, s->pointer++, data);
+    }
+    return 0;
+}
+
+static uint8_t bmi270_recv(I2CSlave *i2c)
+{
+    BMI270State *s = BMI270(i2c);
+
+    return bmi270_read_register(s, s->pointer++);
+}
+
+static void bmi270_reset(DeviceState *dev)
+{
+    bmi270_reset_registers(BMI270(dev));
+}
+
+static void bmi270_init(Object *obj)
+{
+    BMI270State *s = BMI270(obj);
+
+    s->accel_mg[2] = 1000;
+    object_property_add_str(obj, "sample", bmi270_get_sample,
+                            bmi270_set_sample);
+}
+
+static const VMStateDescription vmstate_bmi270 = {
+    .name = TYPE_BMI270,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (VMStateField[]) {
+        VMSTATE_I2C_SLAVE(parent_obj, BMI270State),
+        VMSTATE_UINT8_ARRAY(registers, BMI270State, BMI270_REGISTER_COUNT),
+        VMSTATE_UINT8(pointer, BMI270State),
+        VMSTATE_BOOL(expect_pointer, BMI270State),
+        VMSTATE_BOOL(init_data_stream, BMI270State),
+        VMSTATE_INT32_ARRAY(accel_mg, BMI270State, 3),
+        VMSTATE_INT32_ARRAY(gyro_mdps, BMI270State, 3),
+        VMSTATE_END_OF_LIST()
+    },
+};
+
+static void bmi270_class_init(ObjectClass *klass, void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+    I2CSlaveClass *sc = I2C_SLAVE_CLASS(klass);
+
+    device_class_set_legacy_reset(dc, bmi270_reset);
+    dc->vmsd = &vmstate_bmi270;
+    sc->event = bmi270_event;
+    sc->recv = bmi270_recv;
+    sc->send = bmi270_send;
+}
+
+static const TypeInfo bmi270_info = {
+    .name = TYPE_BMI270,
+    .parent = TYPE_I2C_SLAVE,
+    .instance_size = sizeof(BMI270State),
+    .instance_init = bmi270_init,
+    .class_init = bmi270_class_init,
+};
+
+static void bmi270_register_types(void)
+{
+    type_register_static(&bmi270_info);
+}
+
+type_init(bmi270_register_types)
