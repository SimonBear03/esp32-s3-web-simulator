diff --git a/hw/input/sticks3_buttons.c b/hw/input/sticks3_buttons.c
new file mode 100644
index 0000000000000000000000000000000000000000..ff8879587b3e73a28f984a11a2c7b306c1d35571
--- /dev/null
+++ b/hw/input/sticks3_buttons.c
@@ -0,0 +1,169 @@
+/*
+ * M5Stack StickS3 physical buttons
+ *
+ * Copyright (c) 2026 SimonBear03 contributors
+ *
+ * SPDX-License-Identifier: GPL-2.0-only
+ */
+
+#include "qemu/osdep.h"
+#include "hw/input/sticks3_buttons.h"
+#include "hw/irq.h"
+#include "migration/vmstate.h"
+#include "qapi/error.h"
+#include "qemu/module.h"
+#include "ui/console.h"
+
+OBJECT_DECLARE_SIMPLE_TYPE(StickS3ButtonsState, STICKS3_BUTTONS)
+
+enum {
+    STICKS3_BUTTON_A,
+    STICKS3_BUTTON_B,
+    STICKS3_BUTTON_COUNT,
+};
+
+struct StickS3ButtonsState {
+    DeviceState parent_obj;
+
+    qemu_irq outputs[STICKS3_BUTTON_COUNT];
+    bool pressed[STICKS3_BUTTON_COUNT];
+    QemuInputHandlerState *input_handler;
+};
+
+static int sticks3_button_for_qcode(QKeyCode qcode)
+{
+    switch (qcode) {
+    case Q_KEY_CODE_A:
+        return STICKS3_BUTTON_A;
+    case Q_KEY_CODE_B:
+        return STICKS3_BUTTON_B;
+    default:
+        return -1;
+    }
+}
+
+static void sticks3_buttons_set_pressed(StickS3ButtonsState *s, int button,
+                                         bool pressed)
+{
+    if (s->pressed[button] == pressed) {
+        return;
+    }
+    s->pressed[button] = pressed;
+    qemu_set_irq(s->outputs[button], !pressed);
+}
+
+static void sticks3_buttons_input_event(DeviceState *dev, QemuConsole *src,
+                                         InputEvent *evt)
+{
+    StickS3ButtonsState *s = STICKS3_BUTTONS(dev);
+    InputKeyEvent *key = evt->u.key.data;
+    QKeyCode qcode = qemu_input_key_value_to_qcode(key->key);
+    int button = sticks3_button_for_qcode(qcode);
+
+    if (button < 0) {
+        return;
+    }
+    sticks3_buttons_set_pressed(s, button, key->down);
+}
+
+static const QemuInputHandler sticks3_buttons_input_handler = {
+    .name = "StickS3 buttons",
+    .mask = INPUT_EVENT_MASK_KEY,
+    .event = sticks3_buttons_input_event,
+};
+
+static bool sticks3_buttons_get_a(Object *obj, Error **errp)
+{
+    return STICKS3_BUTTONS(obj)->pressed[STICKS3_BUTTON_A];
+}
+
+static void sticks3_buttons_set_a(Object *obj, bool value, Error **errp)
+{
+    sticks3_buttons_set_pressed(STICKS3_BUTTONS(obj), STICKS3_BUTTON_A,
+                                value);
+}
+
+static bool sticks3_buttons_get_b(Object *obj, Error **errp)
+{
+    return STICKS3_BUTTONS(obj)->pressed[STICKS3_BUTTON_B];
+}
+
+static void sticks3_buttons_set_b(Object *obj, bool value, Error **errp)
+{
+    sticks3_buttons_set_pressed(STICKS3_BUTTONS(obj), STICKS3_BUTTON_B,
+                                value);
+}
+
+static void sticks3_buttons_reset(DeviceState *dev)
+{
+    StickS3ButtonsState *s = STICKS3_BUTTONS(dev);
+    unsigned int index;
+
+    memset(s->pressed, 0, sizeof(s->pressed));
+    for (index = 0; index < STICKS3_BUTTON_COUNT; index++) {
+        qemu_set_irq(s->outputs[index], 1);
+    }
+}
+
+static void sticks3_buttons_init(Object *obj)
+{
+    object_property_add_bool(obj, "button-a", sticks3_buttons_get_a,
+                             sticks3_buttons_set_a);
+    object_property_add_bool(obj, "button-b", sticks3_buttons_get_b,
+                             sticks3_buttons_set_b);
+}
+
+static void sticks3_buttons_realize(DeviceState *dev, Error **errp)
+{
+    StickS3ButtonsState *s = STICKS3_BUTTONS(dev);
+
+    qdev_init_gpio_out_named(dev, s->outputs, "button", STICKS3_BUTTON_COUNT);
+    s->input_handler = qemu_input_handler_register(
+        dev, &sticks3_buttons_input_handler);
+}
+
+static void sticks3_buttons_unrealize(DeviceState *dev)
+{
+    StickS3ButtonsState *s = STICKS3_BUTTONS(dev);
+
+    if (s->input_handler) {
+        qemu_input_handler_unregister(s->input_handler);
+        s->input_handler = NULL;
+    }
+}
+
+static const VMStateDescription vmstate_sticks3_buttons = {
+    .name = TYPE_STICKS3_BUTTONS,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (VMStateField[]) {
+        VMSTATE_BOOL_ARRAY(pressed, StickS3ButtonsState,
+                           STICKS3_BUTTON_COUNT),
+        VMSTATE_END_OF_LIST()
+    },
+};
+
+static void sticks3_buttons_class_init(ObjectClass *klass, void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->realize = sticks3_buttons_realize;
+    dc->unrealize = sticks3_buttons_unrealize;
+    device_class_set_legacy_reset(dc, sticks3_buttons_reset);
+    dc->vmsd = &vmstate_sticks3_buttons;
+}
+
+static const TypeInfo sticks3_buttons_info = {
+    .name = TYPE_STICKS3_BUTTONS,
+    .parent = TYPE_DEVICE,
+    .instance_size = sizeof(StickS3ButtonsState),
+    .instance_init = sticks3_buttons_init,
+    .class_init = sticks3_buttons_class_init,
+};
+
+static void sticks3_buttons_register_types(void)
+{
+    type_register_static(&sticks3_buttons_info);
+}
+
+type_init(sticks3_buttons_register_types)
