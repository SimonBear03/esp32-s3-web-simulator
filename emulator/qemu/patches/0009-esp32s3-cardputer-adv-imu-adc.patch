diff --git a/hw/xtensa/esp32s3.c b/hw/xtensa/esp32s3.c
index a66a3dd220c7b1c578556ae017614bb94464699b..36acde7cdd7ec64d4e58e693a669bee82480db95 100644
--- a/hw/xtensa/esp32s3.c
+++ b/hw/xtensa/esp32s3.c
@@ -65,6 +65,7 @@
 #include "hw/gpio/esp32s3_gpio.h"
