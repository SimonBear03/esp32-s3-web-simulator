 system_ss.add(when: 'CONFIG_ASPEED_SOC', if_true: files('aspeed_adc.c'))
 system_ss.add(when: 'CONFIG_NPCM7XX', if_true: files('npcm7xx_adc.c'))
 system_ss.add(when: 'CONFIG_ZYNQ', if_true: files('zynq-xadc.c'))
diff --git a/hw/nvram/esp32s3_efuse.c b/hw/nvram/esp32s3_efuse.c
index df6c0c8742009af1766c4779939c52e91e1cfca6..f6e112d852d45636b779d6157e4bd8f22f7104d1 100644
--- a/hw/nvram/esp32s3_efuse.c
+++ b/hw/nvram/esp32s3_efuse.c
@@ -15,8 +15,17 @@
 static void esp32s3_efuse_realize(DeviceState *dev, Error **errp)
 {
     ESP32S3EfuseClass* esp32s3_class = ESP32S3_EFUSE_GET_CLASS(dev);
+    ESPEfuseState *s = ESP_EFUSE(dev);
 
     esp32s3_class->parent_realize(dev, errp);
+
+    if (s->blk == NULL) {
+        assert(s->mirror != NULL);
+
+        /* Expose revision-one ADC calibration fields with nominal values. */
+        s->efuses.blocks.rd_sys_part1_data4 |= 1;
+        memcpy(s->mirror, &s->efuses.blocks, sizeof(ESPEfuseBlocks));
+    }
 }
 
 
diff --git a/hw/xtensa/Kconfig b/hw/xtensa/Kconfig
