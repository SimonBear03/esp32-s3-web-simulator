 #include "hw/input/tca8418.h"
 #include "hw/input/sticks3_buttons.h"
 #include "hw/sensor/bmi270.h"
@@ -137,6 +138,7 @@ typedef struct Esp32s3SocState {
     Esp32LEDCState ledc;
     Esp32s3RngState rng;
     Esp32S3TWAIState twai;
+    Esp32s3SarAdcState saradc;
 
     Esp32s3RtcCntlState rtc_cntl;
 
@@ -721,6 +723,9 @@ static void esp32s3_machine_init_board_devices(Esp32s3MachineState *ms,
         qdev_connect_gpio_out_named(DEVICE(keyboard), "nINT", 0,
                                     keyboard_irq);
         qemu_set_irq(keyboard_irq, 1);
+        imu = i2c_slave_new(TYPE_BMI270, 0x68);
+        qdev_set_id(DEVICE(imu), g_strdup("cardputer-adv-imu"), &error_fatal);
+        i2c_slave_realize_and_unref(imu, i2c_bus, &error_fatal);
 
         display_width = 240;
         display_height = 135;
@@ -834,6 +839,8 @@ static void esp32s3_machine_init(MachineState *machine)
     object_initialize_child(OBJECT(ss), "jtag", &ss->jtag, TYPE_ESP32C3_JTAG);
     object_initialize_child(OBJECT(ss), "gpio", &ss->gpio, TYPE_ESP32S3_GPIO);
     object_initialize_child(OBJECT(ss), "rng", &ss->rng, TYPE_ESP32S3_RNG);
+    object_initialize_child(OBJECT(ss), "saradc", &ss->saradc,
+                            TYPE_ESP32S3_SARADC);
 
     object_initialize_child(OBJECT(ss), "clock", &ss->clock, TYPE_ESP32S3_CLOCK);
 
@@ -982,6 +989,17 @@ static void esp32s3_machine_init(MachineState *machine)
         memory_region_add_subregion_overlap(sys_mem, DR_REG_LEDC_BASE, mr, 0);
     }
 
+    /* RTC one-shot and digital SAR ADC register blocks. */
+    {
+        sysbus_realize(SYS_BUS_DEVICE(&ss->saradc), &error_fatal);
+        memory_region_add_subregion_overlap(
+            sys_mem, DR_REG_SENS_BASE,
+            sysbus_mmio_get_region(SYS_BUS_DEVICE(&ss->saradc), 0), 0);
+        memory_region_add_subregion_overlap(
+            sys_mem, DR_REG_APB_SARADC_BASE,
+            sysbus_mmio_get_region(SYS_BUS_DEVICE(&ss->saradc), 1), 0);
+    }
+
     {
         qdev_realize(DEVICE(&ss->rng), &ss->periph_bus, &error_fatal);
         esp32s3_soc_add_periph_device(sys_mem, &ss->rng, ESP32S3_RNG_BASE);
diff --git a/include/hw/adc/esp32s3_saradc.h b/include/hw/adc/esp32s3_saradc.h
new file mode 100644
index 0000000000000000000000000000000000000000..08454b3752af15ee5292085cb5b73953874d3a6a
--- /dev/null
+++ b/include/hw/adc/esp32s3_saradc.h
@@ -0,0 +1,30 @@
+/*
+ * ESP32-S3 SAR ADC behavioral model
+ *
+ * Copyright (c) 2026 Simon Yu
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License version 2 or
+ * (at your option) any later version.
+ */
+#ifndef HW_ADC_ESP32S3_SARADC_H
+#define HW_ADC_ESP32S3_SARADC_H
+
+#include "hw/sysbus.h"
+
+#define TYPE_ESP32S3_SARADC "esp32s3-saradc"
+OBJECT_DECLARE_SIMPLE_TYPE(Esp32s3SarAdcState, ESP32S3_SARADC)
+
+#define ESP32S3_SARADC_REGISTER_WORDS 64
+
+struct Esp32s3SarAdcState {
+    SysBusDevice parent_obj;
+
+    MemoryRegion sens_iomem;
+    MemoryRegion apb_iomem;
+    uint32_t sens_registers[ESP32S3_SARADC_REGISTER_WORDS];
+    uint32_t apb_registers[ESP32S3_SARADC_REGISTER_WORDS];
+    uint16_t adc1_ch9_millivolts;
+};
+
+#endif /* HW_ADC_ESP32S3_SARADC_H */
