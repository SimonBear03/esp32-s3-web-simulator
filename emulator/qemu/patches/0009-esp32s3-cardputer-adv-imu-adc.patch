diff --git a/hw/adc/esp32s3_saradc.c b/hw/adc/esp32s3_saradc.c
new file mode 100644
index 0000000000000000000000000000000000000000..3816962884e28614c6b88ddbd36975adb9c26f73
--- /dev/null
+++ b/hw/adc/esp32s3_saradc.c
@@ -0,0 +1,210 @@
+/*
+ * ESP32-S3 SAR ADC behavioral model
+ *
+ * Copyright (c) 2026 Simon Yu
+ *
+ * This program is free software; you can redistribute it and/or modify
+ * it under the terms of the GNU General Public License version 2 or
+ * (at your option) any later version.
+ *
+ * The initial model covers RTC-controller one-shot ADC1 conversions. This is
+ * the path used by M5Unified to sample the Cardputer ADV battery divider on
+ * ADC1 channel 9 (GPIO10). Other channels return zero until they are modeled.
+ */
+
+#include "qemu/osdep.h"
+#include "hw/adc/esp32s3_saradc.h"
+#include "migration/vmstate.h"
+#include "qemu/module.h"
+#include "qemu/units.h"
+
+#define ESP32S3_SARADC_SENS_CTRL2 0x0c
+#define ESP32S3_SARADC_SENS_ATTEN1 0x14
+#define ESP32S3_SARADC_APB_ADC1_DATA_STATUS 0x40
+
+#define ESP32S3_SARADC_EN_PAD_SHIFT 19
+#define ESP32S3_SARADC_EN_PAD_MASK (0xfffU << ESP32S3_SARADC_EN_PAD_SHIFT)
+#define ESP32S3_SARADC_START BIT(17)
+#define ESP32S3_SARADC_DONE BIT(16)
+#define ESP32S3_SARADC_DATA_MASK 0xffffU
+#define ESP32S3_SARADC_MAX_RAW 4095U
+
+static unsigned esp32s3_saradc_selected_channel(uint32_t ctrl2)
+{
+    uint32_t bitmap = (ctrl2 & ESP32S3_SARADC_EN_PAD_MASK) >>
+                      ESP32S3_SARADC_EN_PAD_SHIFT;
+
+    return bitmap ? ctz32(bitmap) : 0;
+}
+
+static uint16_t esp32s3_saradc_convert_adc1(Esp32s3SarAdcState *s,
+                                             unsigned channel)
+{
+    uint32_t raw;
+
+    if (channel != 9) {
+        return 0;
+    }
+
+    /*
+     * Approximate the ESP32-S3 ADC1 attenuation-3 transfer curve around the
+     * Li-ion range. The virtual chip exposes calibration eFuses, so Espressif's
+     * firmware calibration path converts this raw value back to millivolts.
+     */
+    raw = ((uint32_t)s->adc1_ch9_millivolts + 40U) * 900U / 850U;
+    return MIN(raw, ESP32S3_SARADC_MAX_RAW);
+}
+
+static void esp32s3_saradc_start_adc1(Esp32s3SarAdcState *s)
+{
+    uint32_t *ctrl2 = &s->sens_registers[ESP32S3_SARADC_SENS_CTRL2 / 4];
+    uint16_t raw = esp32s3_saradc_convert_adc1(
+        s, esp32s3_saradc_selected_channel(*ctrl2));
+
+    *ctrl2 = (*ctrl2 & ~ESP32S3_SARADC_DATA_MASK) |
+             ESP32S3_SARADC_DONE | raw;
+    s->apb_registers[ESP32S3_SARADC_APB_ADC1_DATA_STATUS / 4] = raw;
+}
+
+static uint64_t esp32s3_saradc_read_register(uint32_t *registers,
+                                              hwaddr offset)
+{
+    if (offset >= ESP32S3_SARADC_REGISTER_WORDS * sizeof(uint32_t)) {
+        return 0;
+    }
+    return registers[offset / sizeof(uint32_t)];
+}
+
+static void esp32s3_saradc_write_register(uint32_t *registers,
+                                           hwaddr offset, uint64_t value)
+{
+    if (offset < ESP32S3_SARADC_REGISTER_WORDS * sizeof(uint32_t)) {
+        registers[offset / sizeof(uint32_t)] = (uint32_t)value;
+    }
+}
+
+static uint64_t esp32s3_saradc_sens_read(void *opaque, hwaddr offset,
+                                         unsigned size)
+{
+    Esp32s3SarAdcState *s = opaque;
+
+    return esp32s3_saradc_read_register(s->sens_registers, offset);
+}
+
+static void esp32s3_saradc_sens_write(void *opaque, hwaddr offset,
+                                      uint64_t value, unsigned size)
+{
+    Esp32s3SarAdcState *s = opaque;
+    uint32_t previous = esp32s3_saradc_read_register(s->sens_registers,
+                                                      offset);
+
+    esp32s3_saradc_write_register(s->sens_registers, offset, value);
+    if (offset == ESP32S3_SARADC_SENS_CTRL2 &&
+        !(previous & ESP32S3_SARADC_START) &&
+        (value & ESP32S3_SARADC_START)) {
+        esp32s3_saradc_start_adc1(s);
+    }
+}
+
+static uint64_t esp32s3_saradc_apb_read(void *opaque, hwaddr offset,
+                                        unsigned size)
+{
+    Esp32s3SarAdcState *s = opaque;
+
+    return esp32s3_saradc_read_register(s->apb_registers, offset);
+}
+
+static void esp32s3_saradc_apb_write(void *opaque, hwaddr offset,
+                                     uint64_t value, unsigned size)
+{
+    Esp32s3SarAdcState *s = opaque;
+
+    esp32s3_saradc_write_register(s->apb_registers, offset, value);
+}
+
+static const MemoryRegionOps esp32s3_saradc_sens_ops = {
+    .read = esp32s3_saradc_sens_read,
+    .write = esp32s3_saradc_sens_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid = {
+        .min_access_size = 4,
+        .max_access_size = 4,
+        .unaligned = false,
+    },
+};
+
+static const MemoryRegionOps esp32s3_saradc_apb_ops = {
+    .read = esp32s3_saradc_apb_read,
+    .write = esp32s3_saradc_apb_write,
+    .endianness = DEVICE_LITTLE_ENDIAN,
+    .valid = {
+        .min_access_size = 4,
+        .max_access_size = 4,
+        .unaligned = false,
+    },
+};
+
+static void esp32s3_saradc_reset(DeviceState *dev)
+{
+    Esp32s3SarAdcState *s = ESP32S3_SARADC(dev);
+
+    memset(s->sens_registers, 0, sizeof(s->sens_registers));
+    memset(s->apb_registers, 0, sizeof(s->apb_registers));
+    s->sens_registers[0] = BIT(29) | BIT(18) | 2;
+    s->sens_registers[ESP32S3_SARADC_SENS_ATTEN1 / 4] = UINT32_MAX;
+}
+
+static void esp32s3_saradc_init(Object *obj)
+{
+    Esp32s3SarAdcState *s = ESP32S3_SARADC(obj);
+    SysBusDevice *sbd = SYS_BUS_DEVICE(obj);
+
+    memory_region_init_io(&s->sens_iomem, obj, &esp32s3_saradc_sens_ops, s,
+                          TYPE_ESP32S3_SARADC ".sens", 4 * KiB);
+    sysbus_init_mmio(sbd, &s->sens_iomem);
+    memory_region_init_io(&s->apb_iomem, obj, &esp32s3_saradc_apb_ops, s,
+                          TYPE_ESP32S3_SARADC ".apb", 4 * KiB);
+    sysbus_init_mmio(sbd, &s->apb_iomem);
+    object_property_add_uint16_ptr(obj, "adc1-ch9-millivolts",
+                                   &s->adc1_ch9_millivolts,
+                                   OBJ_PROP_FLAG_READWRITE);
+    s->adc1_ch9_millivolts = 1950;
+}
+
+static const VMStateDescription vmstate_esp32s3_saradc = {
+    .name = TYPE_ESP32S3_SARADC,
+    .version_id = 1,
+    .minimum_version_id = 1,
+    .fields = (const VMStateField[]) {
+        VMSTATE_UINT32_ARRAY(sens_registers, Esp32s3SarAdcState,
+                             ESP32S3_SARADC_REGISTER_WORDS),
+        VMSTATE_UINT32_ARRAY(apb_registers, Esp32s3SarAdcState,
+                             ESP32S3_SARADC_REGISTER_WORDS),
+        VMSTATE_UINT16(adc1_ch9_millivolts, Esp32s3SarAdcState),
+        VMSTATE_END_OF_LIST(),
+    },
+};
+
+static void esp32s3_saradc_class_init(ObjectClass *klass, void *data)
+{
+    DeviceClass *dc = DEVICE_CLASS(klass);
+
+    dc->desc = "ESP32-S3 SAR ADC behavioral model";
+    dc->vmsd = &vmstate_esp32s3_saradc;
+    device_class_set_legacy_reset(dc, esp32s3_saradc_reset);
+}
+
+static const TypeInfo esp32s3_saradc_info = {
+    .name = TYPE_ESP32S3_SARADC,
+    .parent = TYPE_SYS_BUS_DEVICE,
+    .instance_size = sizeof(Esp32s3SarAdcState),
+    .instance_init = esp32s3_saradc_init,
+    .class_init = esp32s3_saradc_class_init,
+};
+
+static void esp32s3_saradc_register_types(void)
+{
+    type_register_static(&esp32s3_saradc_info);
+}
+
+type_init(esp32s3_saradc_register_types)
