From 0000000000000000000000000000000000000010 Mon Sep 17 00:00:00 2001
From: ESP32-S3 Web Simulator contributors <noreply@example.com>
Date: Sun, 19 Jul 2026 21:00:00 +0800
Subject: [PATCH 10/11] esp32s3: add peripheral trace points

Add worker-originated trace points at the behavioral boundaries used by
the simulator diagnostics service: ESP32-S3 GPIO input/output, GPSPI
transactions, ST7789 commands and windows, board input, injected IMU and
power state, and SAR ADC conversion. Existing QEMU I2C core trace points
cover addressed I2C transfers without duplicating bus instrumentation.
---
 hw/adc/esp32s3_saradc.c     |  4 ++++
 hw/adc/trace-events         |  3 +++
 hw/display/st7789.c         |  2 ++
 hw/display/trace-events     |  4 ++++
 hw/gpio/esp32_gpio.c        | 10 ++++++++--
 hw/gpio/trace-events        |  4 ++++
 hw/input/sticks3_buttons.c  |  2 ++
 hw/input/tca8418.c          |  2 ++
 hw/input/trace-events       |  4 ++++
 hw/misc/m5pm1.c             |  2 ++
 hw/misc/trace-events        |  2 ++
 hw/sensor/bmi270.c          |  4 ++++
 hw/sensor/trace-events      |  3 +++
 hw/ssi/esp32s3_gpspi.c      |  4 ++++
 hw/ssi/trace-events         |  3 +++
 15 files changed, 51 insertions(+), 2 deletions(-)

diff --git a/hw/ssi/esp32s3_gpspi.c b/hw/ssi/esp32s3_gpspi.c
--- a/hw/ssi/esp32s3_gpspi.c
+++ b/hw/ssi/esp32s3_gpspi.c
@@ -13,6 +13,7 @@
 #include "migration/vmstate.h"
 #include "qemu/log.h"
 #include "qemu/module.h"
+#include "trace.h"
 
 #define GPSPI_CMD 0x000
 #define GPSPI_ADDR 0x004
@@ -78,6 +79,9 @@ static void esp32s3_gpspi_transaction(ESP32S3GpspiState *s)
     uint8_t *data = (uint8_t *)s->data;
 
     data_bytes = MIN(data_bytes, sizeof(s->data));
+    trace_esp32s3_gpspi_transaction(
+        s->user, s->user2 & 0xffff, s->addr, data_bytes,
+        !!(s->misc & GPSPI_MISC_CS_KEEP_ACTIVE));
     esp32s3_gpspi_set_cs(s, false);
 
     if (s->user & GPSPI_USER_COMMAND) {
diff --git a/hw/ssi/trace-events b/hw/ssi/trace-events
--- a/hw/ssi/trace-events
+++ b/hw/ssi/trace-events
@@ -63,3 +63,6 @@ allwinner_a10_spi_tx(uint8_t byte) "write 0x%02x"
 allwinner_a10_spi_rx(uint8_t byte) "read 0x%02x"
 allwinner_a10_spi_read(const char* regname, uint32_t value) "reg[%s] => 0x%08x"
 allwinner_a10_spi_write(const char* regname, uint32_t value) "reg[%s] <= 0x%08x"
+
+# esp32s3_gpspi.c
+esp32s3_gpspi_transaction(uint32_t user, uint16_t command, uint32_t address, unsigned int data_bytes, bool keep_cs) "user=0x%08x command=0x%04x address=0x%08x data_bytes=%u keep_cs=%d"
