diff --git a/hw/gpio/esp32_gpio.c b/hw/gpio/esp32_gpio.c
--- a/hw/gpio/esp32_gpio.c
+++ b/hw/gpio/esp32_gpio.c
@@ -18,6 +18,7 @@
 #include "hw/irq.h"
 #include "hw/qdev-properties.h"
 #include "hw/gpio/esp32_gpio.h"
+#include "trace.h"
 
 #define S3_GPIO_OUT 0x04
 #define S3_GPIO_OUT_W1TS 0x08
@@ -90,8 +91,10 @@ static void esp32_gpio_update_outputs(Esp32GpioState *s, uint64_t changed,
          * when the software output-enable bit is clear.
          */
         if (enabled || matrix_write) {
-            qemu_set_irq(s->pin_out[pin],
-                         !!(s->output_level & BIT_ULL(pin)));
+            bool level = !!(s->output_level & BIT_ULL(pin));
+
+            trace_esp32_gpio_output(pin, level, matrix_write);
+            qemu_set_irq(s->pin_out[pin], level);
         }
         changed &= ~BIT_ULL(pin);
     }
@@ -161,6 +164,9 @@ static void esp32_gpio_set_input(void *opaque, int pin, int level)
     if (triggered) {
         s->interrupt_status |= mask;
     }
+    if (previous != !!level) {
+        trace_esp32_gpio_input(pin, level, triggered);
+    }
     esp32_gpio_update_irq(s);
 }
 
diff --git a/hw/gpio/trace-events b/hw/gpio/trace-events
