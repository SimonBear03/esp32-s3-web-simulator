 stm32l4x5_gpio_pins(char *gpio, uint16_t disconnected, uint16_t high) "GPIO%s disconnected pins: 0x%x levels: 0x%x"
+
+# esp32_gpio.c
+esp32_gpio_input(unsigned int pin, bool level, bool triggered) "pin=%u level=%d interrupt=%d"
+esp32_gpio_output(unsigned int pin, bool level, bool matrix_write) "pin=%u level=%d matrix=%d"
